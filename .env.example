# ═══════════════════════════════════════════════
#  psych — Trading Psychology Companion
#  Environment Variables
# ═══════════════════════════════════════════════

# ── Database (Neon Postgres) ──────────────────
# Required for caching and persistence. Get from Vercel Neon integration or neon.tech dashboard.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── AI / LLM ─────────────────────────────────
# OpenAI-compatible API. Required for chat features.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── Solana Data Providers ─────────────────────
# Helius: REQUIRED for on-chain swap data. Get a free key at helius.dev
HELIUS_API_KEY=your-helius-api-key

# Jupiter: REQUIRED for token pricing (SOL + all traded tokens).
# 1 RPS rate limit. Get a key at station.jup.ag
JUPITER_API_KEY=your-jupiter-api-key

# Birdeye: Optional, used for historical price charts + extra token coverage.
BIRDEYE_API_KEY=your-birdeye-api-key

# ── App Config ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
